<?xml version="1.0" encoding="utf-8"?>
<!-- Simplified US flag: 13 alternating red/white stripes + blue canton (no stars for clarity at small size) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- White base (provides white stripes between red ones) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M0,0 H24 V24 H0 Z" />

    <!-- Red stripes — 7 stripes at ~1.85 height each (13 total: 7 red, 6 white) -->
    <path android:fillColor="#B22234" android:pathData="M0,0 H24 V1.85 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,3.69 H24 V5.54 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,7.38 H24 V9.23 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,11.08 H24 V12.92 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,14.77 H24 V16.62 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,18.46 H24 V20.31 H0 Z" />
    <path android:fillColor="#B22234" android:pathData="M0,22.15 H24 V24 H0 Z" />

    <!-- Blue canton — upper left, covers top 4 stripes height -->
    <path
        android:fillColor="#3C3B6E"
        android:pathData="M0,0 H10 V7.4 H0 Z" />

</vector>
